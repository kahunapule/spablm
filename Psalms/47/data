\c 47
\d Al director musical. Salmo de los hijos de Coré.
\q1
\v 1 Pueblos todos, batid las manos;
\q2 aclamad a Dios con voz de júbilo.
\q1
\v 2 Porque Yahvé el Altísimo es temible;
\q2 Rey grande sobre toda la tierra.
\q1
\v 3 Él someterá a los pueblos debajo de nosotros,
\q2 y a las naciones debajo de nuestros pies.
\q1
\v 4 Él nos elegirá nuestras heredades,
\q2 la hermosura de Jacob, al cual amó. Selah.
\q1
\v 5 Subió Dios con júbilo,
\q2 Yahvé con sonido de trompeta.
\q1
\v 6 Cantad a Dios, cantad;
\q2 cantad a nuestro Rey, cantad.
\q1
\v 7 Porque Dios es el Rey de toda la tierra;
\q2 cantad con inteligencia.
\q1
\v 8 Reinó Dios sobre las naciones;
\q2 se sentó Dios sobre su santo trono.
\q1
\v 9 Los príncipes de los pueblos se reunieron,
\q1 como pueblo del Dios de Abraham;
\q2 porque de Dios son los escudos de la tierra;
\q2 él es muy exaltado.