\c 149
\q1
\v 1 ¡Alabado sea Yah!
\q2 Cantad a Yahvé cántico nuevo;
\q2 su alabanza en la congregación de los santos.
\q1
\v 2 Alégrese Israel en su Hacedor;
\q2 los hijos de Sión se gocen en su Rey.
\q1
\v 3 Alaben su nombre con danza;
\q2 con pandero y arpa a él canten.
\q1
\v 4 Porque Yahvé tiene contentamiento en su pueblo;
\q2 hermoseará a los humildes con la salvación.
\q1
\v 5 Regocíjense los santos por su gloria,
\q2 y canten aun sobre sus lechos.
\q1
\v 6 Exalten a Dios con sus gargantas,
\q2 y espadas de dos filos en sus manos,
\q1
\v 7 para ejecutar venganza entre las naciones,
\q2 y castigo entre los pueblos;
\q1
\v 8 para aprisionar a sus reyes con cadenas,
\q2 y a sus nobles con grillos de hierro;
\q1
\v 9 para ejecutar en ellos el juicio decretado;
\q2 gloria será esto para todos sus santos.
\q1 ¡Alabado sea Yah!
\b