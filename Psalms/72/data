\c 72
\d Para Salomón.
\q1
\v 1 Oh Dios, da tus juicios al rey,
\q2 y tu justicia al hijo del rey.
\q1
\v 2 Él juzgará a tu pueblo con justicia,
\q2 y a tus afligidos con rectitud.
\q1
\v 3 Los montes llevarán paz al pueblo,
\q2 y los collados el fruto de la justicia.
\q1
\v 4 Juzgará a los pobres del pueblo,
\q2 salvará a los hijos del menesteroso,
\q2 y quebrantará al opresor.
\q1
\v 5 Te temerán mientras duren el sol
\q2 y la luna, de generación en generación.
\q1
\v 6 Descenderá como la lluvia sobre la hierba cortada,
\q2 como aguaceros que riegan la tierra.
\q1
\v 7 Florecerá el justo en sus días,
\q2 y habrá abundancia de paz, hasta que no haya luna.
\q1
\v 8 Dominará de mar a mar,
\q2 y desde el río hasta los confines de la tierra.
\q1
\v 9 Ante él se postrarán los moradores del desierto,
\q2 y sus enemigos lamerán el polvo.
\q1
\v 10 Los reyes de Tarsis y de las costas traerán presentes;
\q2 los reyes de Sabá y de Seba ofrecerán dones.
\q1
\v 11 Todos los reyes se postrarán delante de él;
\q2 todas las naciones le servirán.
\q1
\v 12 Porque él librará al menesteroso que clame,
\q2 y al pobre que no tuviere quien le socorra.
\q1
\v 13 Tendrá misericordia del pobre y del menesteroso,
\q2 y salvará la vida de los necesitados.
\q1
\v 14 De engaño y de violencia redimirá sus almas,
\q2 y la sangre de ellos será preciosa ante sus ojos.
\q1
\v 15 Vivirá, y se le dará del oro de Sabá.
\q2 Orarán por él continuamente;
\q2 todo el día lo bendecirán.
\q1
\v 16 Habrá abundancia de grano en la tierra, en las cumbres de los montes;
\q2 su fruto ondeará como el Líbano,
\q2 y los de la ciudad florecerán como la hierba del campo.
\q1
\v 17 Será su nombre para siempre,
\q2 perdurará su nombre mientras dure el sol.
\q1 Serán benditas en él todas las naciones;
\q2 lo llamarán bienaventurado.
\b
\q1
\v 18 Bendito sea Yahvé Dios, el Dios de Israel,
\q2 el único que hace maravillas.
\q1
\v 19 ¡Bendito sea su glorioso nombre para siempre!
\q2 ¡Toda la tierra sea llena de su gloria!
\q1 Amén y amén.
\b
\p
\v 20 Aquí terminan las oraciones de David, hijo de Jesé.