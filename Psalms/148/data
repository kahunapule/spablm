\c 148
\q1
\v 1 ¡Alabado sea Yah!
\q2 ¡Alabad a Yahvé desde los cielos!
\q2 ¡Alabadle en las alturas!
\q1
\v 2 ¡Alabadle, vosotros todos sus ángeles!
\q2 ¡Alabadle, vosotros todos sus ejércitos!
\q1
\v 3 ¡Alabadle, sol y luna!
\q2 ¡Alabadle, todas las estrellas lucientes!
\q1
\v 4 ¡Alabadle, cielos de los cielos,
\q2 y las aguas que están sobre los cielos!
\q1
\v 5 Alaben el nombre de Yahvé,
\q2 porque él mandó, y fueron creados.
\q1
\v 6 Los estableció eternamente y para siempre;
\q2 les puso ley que no será quebrantada.
\q1
\v 7 Alabad a Yahvé desde la tierra,
\q2 los monstruos marinos y todos los abismos;
\q1
\v 8 el fuego y el granizo, la nieve y el vapor,
\q2 el viento tempestuoso que ejecuta su palabra;
\q1
\v 9 los montes y todos los collados,
\q2 el árbol de fruto y todos los cedros;
\q1
\v 10 las bestias y todo animal,
\q2 los reptiles y las aves;
\q1
\v 11 los reyes de la tierra y todos los pueblos,
\q2 los príncipes y todos los jueces de la tierra;
\q1
\v 12 los jóvenes y también las doncellas,
\q2 los ancianos y los niños.
\q1
\v 13 Alaben el nombre de Yahvé,
\q2 porque solo su nombre es excelso.
\q2 Su gloria es sobre tierra y cielos.
\q1
\v 14 Él ha exaltado el cuerno de su pueblo;
\q2 alaben todos sus santos,
\q2 los hijos de Israel, el pueblo a él cercano.
\q1 ¡Alabado sea Yah!
\b