\c 150
\q1
\v 1 ¡Alabado sea Yah!
\q2 ¡Alabad a Dios en su santuario!
\q2 ¡Alabadle en la magnificencia de su firmamento!
\q1
\v 2 ¡Alabadle por sus proezas!
\q2 ¡Alabadle conforme a la inmensidad de su grandeza!
\q1
\v 3 ¡Alabadle a son de bocina!
\q2 ¡Alabadle con salterio y arpa!
\q1
\v 4 ¡Alabadle con pandero y danza!
\q2 ¡Alabadle con cuerdas y flautas!
\q1
\v 5 ¡Alabadle con címbalos resonantes!
\q2 ¡Alabadle con címbalos de júbilo!
\q1
\v 6 ¡Todo lo que respira alabe a Yah!
\q2 ¡Alabado sea Yah!